# Ray cluster defaults for two-node vLLM model-parallel mode.
# Override these values per host in /etc/qwen-web/ray.env.

RAY_HEAD_IP=192.168.100.1
RAY_WORKER_IP=192.168.100.2
RAY_PORT=6379
RAY_DASHBOARD_PORT=8265
RAY_NODE_MANAGER_PORT=8076
RAY_OBJECT_MANAGER_PORT=8077
RAY_RUNTIME_ENV_AGENT_PORT=8078
RAY_MIN_WORKER_PORT=10002
RAY_MAX_WORKER_PORT=10100
RAY_NUM_GPUS=1
RAY_TEMP_DIR=/tmp/ray

# Set to 1 to print the resolved ray command without starting Ray.
RAY_DRY_RUN=0