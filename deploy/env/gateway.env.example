TEAM_API_KEY=replace-with-strong-key
TEAM_API_KEYS_EXTRA=

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3000
WEB_ROOT=/opt/qwen-web
VLLM_BASE=http://127.0.0.1:8000
# Optional comma-separated upstreams for dual-node replica mode. Overrides VLLM_BASE when set.
# Example: VLLM_BASES=http://127.0.0.1:8000,http://192.168.100.2:8000
VLLM_BASES=

RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
MAX_CONCURRENT_PER_CLIENT=2
MAX_GLOBAL_INFLIGHT=32
MAX_QUEUE_SIZE=128
QUEUE_WAIT_MS=20000
UPSTREAM_TIMEOUT_MS=180000
METRIC_WINDOW_SIZE=400

STATIC_CACHE_SECONDS=300
ENABLE_WEB_AUTH_BYPASS=false
ALLOW_INSECURE_DEFAULT_KEY=false
# Multimodal Web upload capability exposed via /frontend/config.
# Uploads are validated by the gateway and kept in memory only; files are not persisted.
MULTIMODAL_IMAGE_ENABLED=false
MULTIMODAL_AUDIO_ENABLED=false
MULTIMODAL_VIDEO_ENABLED=false
MULTIMODAL_FILE_ENABLED=false
MULTIMODAL_MAX_ATTACHMENTS=4
MULTIMODAL_MAX_IMAGE_MB=10
MULTIMODAL_MAX_AUDIO_MB=25
MULTIMODAL_MAX_VIDEO_MB=100
MULTIMODAL_MAX_FILE_MB=25