MODEL_PATH=/path/to/model
SERVED_MODEL_NAME=qwen
PYTHON_BIN=python3

VLLM_HOST=0.0.0.0
VLLM_PORT=8000

GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=65536
KV_CACHE_DTYPE=fp8
ENABLE_PREFIX_CACHING=true
MAX_NUM_BATCHED_TOKENS=4096

# If vLLM is installed in a venv/conda env, point to that exact interpreter.
# Example:
# PYTHON_BIN=/opt/miniconda3/envs/vllm/bin/python

# Optional multimodal limit. Leave blank to omit this argument entirely.
LIMIT_MM_PER_PROMPT='{"image":2,"video":1,"audio":1}'

# Optional extra args for distributed vLLM/Ray or performance tuning.
# Example for a 2-node model-parallel instance after starting a Ray cluster:
# EXTRA_VLLM_ARGS=--distributed-executor-backend ray --pipeline-parallel-size 2
EXTRA_VLLM_ARGS=
